            whileInView={{ opacity: 1, y: 0 }}
            viewport={{ once: true }}
            transition={{ duration: 0.5, ease: GOLDEN_EASE }}
            className="text-center mb-12"
          >
            <div className="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-xs font-semibold uppercase tracking-[2px] mb-6"
              style={{ backgroundColor: 'rgba(117, 62, 247, 0.12)', color: '#753EF7', border: '1px solid rgba(117, 62, 247, 0.2)' }}>
