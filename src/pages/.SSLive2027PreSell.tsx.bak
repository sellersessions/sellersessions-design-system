                      <item.icon className="w-7 h-7" style={{ color: item.color }} />
                    </div>
                    <div>
                      <h3 className="text-lg font-bold text-white mb-2">{item.title}</h3>
                      <p className="text-white/70 text-sm leading-relaxed">{item.desc}</p>
                    </div>
                  </div>
                </Card>
              </motion.div>
