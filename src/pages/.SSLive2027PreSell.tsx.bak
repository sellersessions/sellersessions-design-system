/**
 * Seller Sessions Live 2027 - Pre-Sell Landing Page
 * Goes live within days of SSL 2026 (9 May 2026)
 *
 * Pricing model: 72-hour 50% off window post-event (£499.50),
 * then full price £999.
 *
 * S1: Hero (WHY) — animated SVG + Claude Code focus
 * S2: Claude Code value (WHY) — what you'll master
 * S3: What You'll Build (WHAT) — skills, agents, automations
 * S4: Event Details + Price (WHAT IF) — 72hr urgency
 * S5: Final CTA (WHAT IF) — countdown urgency
 *
 * v8 — QA gauntlet fixes + full-width layout + logo fix + consistent CTAs
 */

import { useState } from 'react'
import { motion, useReducedMotion } from 'framer-motion'
import { Container } from '../components/Container'
import { Section } from '../components/Section'
import { Card } from '../components/Card'
import { Button } from '../components/Button'
import { HyperText } from '../components/HyperText'
import {
  Calendar,
  Terminal,
  Bot,
  Workflow,
  GitBranch,
  Layers,
  Clock,
  ArrowRight,
} from 'lucide-react'

/* ─── Golden easing from design-db/animation.csv ─── */
const GOLDEN_EASE = [0.16, 1, 0.3, 1] as const

/* ─── Animated SVG: floating terminal brackets ─── */
function FloatingTerminal({ reducedMotion }: { reducedMotion: boolean }) {
  if (reducedMotion) return null
  return (
    <div className="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
      <motion.svg
        viewBox="0 0 60 60" className="absolute w-16 h-16 opacity-[0.07]"
        style={{ top: '15%', left: '8%' }}
        animate={{ y: [0, -12, 0], rotate: [0, 5, 0] }}
        transition={{ duration: 6, repeat: Infinity, ease: 'easeInOut' }}
      >
        <text x="10" y="42" fill="#753EF7" fontSize="40" fontFamily="monospace" fontWeight="bold">&gt;_</text>
      </motion.svg>

      <motion.svg
        viewBox="0 0 40 80" className="absolute w-10 h-20 opacity-[0.05]"
        style={{ top: '25%', right: '12%' }}
        animate={{ y: [0, 10, 0], rotate: [0, -3, 0] }}
        transition={{ duration: 8, repeat: Infinity, ease: 'easeInOut', delay: 1 }}
      >
        <text x="5" y="60" fill="#F97316" fontSize="64" fontFamily="monospace">{'{'}</text>
      </motion.svg>

      <motion.svg
        viewBox="0 0 40 60" className="absolute w-8 h-12 opacity-[0.06]"
        style={{ bottom: '20%', left: '15%' }}
        animate={{ y: [0, -8, 0] }}
        transition={{ duration: 7, repeat: Infinity, ease: 'easeInOut', delay: 2 }}
      >
        <text x="5" y="45" fill="#753EF7" fontSize="48" fontFamily="monospace">/</text>
      </motion.svg>

      <motion.svg
        viewBox="0 0 100 100" className="absolute w-24 h-24 opacity-[0.04]"
        style={{ top: '60%', right: '8%' }}
        animate={{ rotate: [0, 90, 0] }}
        transition={{ duration: 20, repeat: Infinity, ease: 'linear' }}
      >
        {[0, 1, 2, 3].map(row =>
          [0, 1, 2, 3].map(col => (
            <circle key={`${row}-${col}`} cx={15 + col * 25} cy={15 + row * 25} r="2" fill="#753EF7" />
          ))
        )}
      </motion.svg>
    </div>
  )
}

/* ─── Animated SVG: pulsing rings (Claude/AI aesthetic) ─── */
function PulsingRings({ reducedMotion }: { reducedMotion: boolean }) {
  if (reducedMotion) return null
  return (
    <div className="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
      <svg className="absolute w-full h-full" viewBox="0 0 1440 900" preserveAspectRatio="xMidYMid slice">
        {[300, 500, 700].map((r, i) => (
          <motion.circle
            key={i}
            cx="720" cy="450" r={r}
            fill="none"
            stroke="rgba(117, 62, 247, 0.04)"
            strokeWidth="1"
            initial={{ scale: 0.95, opacity: 0 }}
            animate={{ scale: [0.95, 1.05, 0.95], opacity: [0.03, 0.06, 0.03] }}
            transition={{ duration: 4 + i * 2, repeat: Infinity, ease: 'easeInOut', delay: i * 0.8 }}
          />
        ))}
      </svg>
    </div>
  )
}

/* ─── Countdown timer (72-hour window) ─── */
function CountdownBadge({ reducedMotion }: { reducedMotion: boolean }) {
  return (
    <div
      className="relative inline-flex items-center gap-2 px-4 py-2 rounded-lg"
      style={{
        background: 'linear-gradient(135deg, rgba(249, 115, 22, 0.15) 0%, rgba(117, 62, 247, 0.15) 100%)',
        border: '1px solid rgba(249, 115, 22, 0.2)',
      }}
    >
      {!reducedMotion && (
        <motion.div
          className="absolute inset-0 rounded-lg pointer-events-none"
          style={{ boxShadow: '0 0 25px rgba(249,115,22,0.15)' }}
          animate={{ opacity: [0.4, 1, 0.4] }}
          transition={{ duration: 2, repeat: Infinity, ease: 'easeInOut' }}
        />
      )}
      <Clock className="w-4 h-4 text-ss-orange" />
      <span className="text-sm font-semibold text-white/90">72-Hour Window</span>
      <span className="text-sm text-white/70">|</span>
      <span className="text-sm font-bold text-ss-orange">50% Off</span>
    </div>
  )
}

const IMAGES = {
  logo: 'https://sellersessions.com/wp-content/uploads/2025/02/Seller-Sessions-Live-horizontal-Logo-NC.png',
}

const CHECKOUT_URL = '#get-tickets'

export default function SSLive2027PreSell() {
  const prefersReducedMotion = useReducedMotion() ?? false
  const [ticketLoading, setTicketLoading] = useState(false)

  const handleTicketClick = (e: React.MouseEvent) => {
