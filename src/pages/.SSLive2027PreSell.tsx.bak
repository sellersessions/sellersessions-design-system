              <h2 className="text-2xl md:text-4xl font-bold mb-6 text-white">
                Saturday 8 May 2027
              </h2>
              <div className="space-y-3 text-white/70 text-lg">
                <p>London</p>
                <p>Full Day Conference + Evening Dinner</p>
                <p>Networking with 7 and 8-figure sellers</p>
