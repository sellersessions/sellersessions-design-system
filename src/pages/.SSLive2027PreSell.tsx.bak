                src={IMAGES.logo}
                alt="Seller Sessions Live"
                className="h-14 md:h-20 w-auto max-w-md mx-auto mb-8 object-contain"
              />

              {/* Headline */}
              <motion.h1
                initial={{ opacity: 0, y: 20 }}
                animate={{ opacity: 1, y: 0 }}
                transition={{ delay: 0.3, ease: GOLDEN_EASE }}
                className="text-3xl md:text-5xl lg:text-[56px] font-bold mb-4 leading-tight text-white"
              >
                Build Your Business<br />
                <HyperText text="With Claude Code" className="text-ss-accent" duration={1800} />
              </motion.h1>

              {/* Subheadline */}
              <motion.p
                initial={{ opacity: 0, y: 20 }}
                animate={{ opacity: 1, y: 0 }}
                transition={{ delay: 0.45, ease: GOLDEN_EASE }}
                className="text-lg md:text-xl mb-10 text-white/70"
              >
                One day. One tool. Everything changes.
              </motion.p>

              {/* CTA */}
              <motion.div
                initial={{ opacity: 0, y: 20 }}
                animate={{ opacity: 1, y: 0 }}
                transition={{ delay: 0.6, ease: GOLDEN_EASE }}
                className="flex flex-wrap justify-center gap-4"
              >
                <Button
