      </Section>

      {/* ═══════════════════════════════════════════
          S3: WHAT YOU'LL BUILD — Concrete takeaways
          ═══════════════════════════════════════════ */}
      <Section id="what-youll-build" className="section-dark relative overflow-hidden py-16 md:py-24">
        <Container size="xl">
          <div className="grid lg:grid-cols-2 gap-12 items-center">
            {/* Left: heading + description */}
            <motion.div
              initial={{ opacity: 0, y: 20 }}
              whileInView={{ opacity: 1, y: 0 }}
              viewport={{ once: true }}
              transition={{ duration: 0.5, ease: GOLDEN_EASE }}
            >
              <h2 className="text-2xl md:text-4xl lg:text-[48px] font-bold mb-4 text-white leading-tight">
                Walk Out With <span className="text-ss-accent">Working Systems</span>
              </h2>
              <p className="text-white/70 text-base leading-[1.8]">
                This isn't theory. You build live alongside the speakers on your own laptop.
                Everything you create is yours to take home and keep using.
              </p>
            </motion.div>

            {/* Right: staggered list */}
            <div className="space-y-3">
              {[
                'Production-ready agents for product research and competitor tracking',
                'Automated reporting pipelines that pull from your Seller Central data',
                'Custom skills and hooks you can install in Claude Code immediately',
                'A framework for building sophisticated multi-agent workflows',
                'Data analysis systems that turn raw numbers into decisions',
                'Evening dinner and networking with 7 and 8-figure sellers',
              ].map((item, i) => (
                <motion.div
