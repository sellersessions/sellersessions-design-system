    <main className="min-h-screen bg-ss-bg">
      <a href="#main-content" className="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:bg-ss-purple focus:text-white focus:px-4 focus:py-2 focus:rounded-lg">
        Skip to main content
      </a>

      {/* ═══════════════════════════════════════════
          S1: HERO — Claude Code focus + animated SVGs
          ═══════════════════════════════════════════ */}
      <header
        id="main-content"
        className="relative overflow-hidden"
        style={{
          minHeight: '90vh',
          display: 'flex', flexDirection: 'column', justifyContent: 'center',
          background: `
            radial-gradient(ellipse at 50% 30%, rgba(117, 62, 247, 0.15) 0%, transparent 60%),
            radial-gradient(ellipse at 20% 70%, rgba(70, 20, 153, 0.10) 0%, transparent 50%),
            radial-gradient(ellipse at 80% 60%, rgba(249, 115, 22, 0.06) 0%, transparent 40%),
            linear-gradient(180deg, #0C0322 0%, #0A0A0A 100%)
          `,
        }}
      >
          <PulsingRings reducedMotion={prefersReducedMotion} />
          <FloatingTerminal reducedMotion={prefersReducedMotion} />

          <Container size="xl" className="relative py-16 md:py-24 text-center" style={{ zIndex: 2 }}>
            <motion.div
              initial={{ opacity: 0, y: 30 }}
              animate={{ opacity: 1, y: 0 }}
              transition={{ duration: 0.6, ease: GOLDEN_EASE }}
            >
              {/* Single combined badge */}
              <motion.div
                initial={{ opacity: 0, y: 20 }}
                animate={{ opacity: 1, y: 0 }}
                transition={{ delay: 0.0, ease: GOLDEN_EASE }}
                className="mb-8"
              >
                <span
                  className="inline-flex flex-wrap items-center justify-center gap-3 px-5 py-2 rounded-full text-sm font-semibold uppercase tracking-[2px]"
                  style={{ backgroundColor: 'rgba(117, 62, 247, 0.12)', border: '1px solid rgba(117, 62, 247, 0.25)' }}
                >
                  <Calendar className="w-4 h-4 text-ss-accent" />
                  <span className="text-white/80">May 8, 2027</span>
                  <span className="text-white/40 hidden sm:inline">|</span>
                  <span className="text-white/80">London</span>
                  <span className="text-white/40 hidden sm:inline">|</span>
                  <span className="text-ss-orange">72hrs at 50% Off</span>
                </span>
              </motion.div>

              {/* Logo */}
              <motion.img
                initial={{ opacity: 0 }}
                animate={{ opacity: 1 }}
