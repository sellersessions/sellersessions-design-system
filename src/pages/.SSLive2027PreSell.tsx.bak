              {
                icon: Bot,
                title: 'Agents That Work For You',
                desc: 'Autonomous agents that handle product research, competitor tracking, and listing optimisation.',
                color: '#753EF7',
              },
              {
                icon: Workflow,
                title: 'Business Automations',
                desc: 'Connect data sources, automate reporting, and trigger actions based on your metrics.',
                color: '#F97316',
              },
              {
                icon: GitBranch,
                title: 'Skills & Repos',
                desc: 'Production-ready skills, hooks, and frameworks you install and use the same day.',
                color: '#FBBF24',
              },
              {
                icon: Layers,
                title: 'Joining the Dots',
                desc: 'Combine agents, automations, and data into one sophisticated system for your business.',
                color: '#753EF7',
              },
            ].map((item, i) => (
