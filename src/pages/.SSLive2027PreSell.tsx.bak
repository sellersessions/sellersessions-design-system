              </motion.div>
            </motion.div>
          </Container>
      </header>

      {/* ═══════════════════════════════════════════
          S2: CLAUDE CODE VALUE — Why this tool changes everything
          ═══════════════════════════════════════════ */}
      <Section id="claude-code" className="section-mid relative overflow-hidden py-16 md:py-24">
        <Container size="xl" className="relative z-10">
          <motion.div
